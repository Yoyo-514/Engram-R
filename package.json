{
  "name": "engram-r",
  "version": "1.0.3",
  "description": "Graph RAG 记忆操作系统 for SillyTavern",
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "vite",
    "dev:watch": "vite build --watch",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prettify": "oxfmt --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "oxlint --config ./.oxlintrc.json --tsconfig ./tsconfig.json .",
    "lint:fix": "oxlint --config ./.oxlintrc.json --tsconfig ./tsconfig.json --fix .",
    "knip": "knip",
    "ci": "pnpm run type-check && pnpm run format:check && pnpm run lint && pnpm run test && pnpm run knip"
  },
  "keywords": [
    "sillytavern",
    "extension",
    "graph-rag",
    "memory"
  ],
  "author": "",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@types/jquery": "^3.5.32",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.3",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.8",
    "@types/toastr": "^2.1.43",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "fake-indexeddb": "^6.2.5",
    "knip": "^5.82.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.15.0",
    "postcss": "^8.5.6",
    "postcss-minify": "^1.2.0",
    "sass": "^1.89.0",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.1",
    "type-fest": "^4.41.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "fast-json-patch": "^3.1.1",
    "framer-motion": "^12.23.26",
    "immer": "^10.1.1",
    "klona": "^2.0.0",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.562.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.1",
    "zod": "^4.3.5",
    "zustand": "^4.5.4"
  }
}
