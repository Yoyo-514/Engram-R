{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "jquery", "type-fest", "toastr"]
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "src/types/**/*.d.ts",
    "@types/**/*.d.ts",
    "manifest.json",
    "vite.config.ts",
    "vitest.config.ts",
    "global.d.ts"
  ],
  "exclude": ["**/node_modules/**", "**/dist/**"]
}
